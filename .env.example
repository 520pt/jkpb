# 服务
TZ=Asia/Shanghai
APP_PORT=8080
DATA_DIR=/app/data
UPLOAD_DIR=/app/uploads
ENABLE_SCHEDULER=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_PASSWORD
MAX_UPLOAD_MB=10
UPLOAD_KEEP_DAYS=90

# LightAgent
LIGHTAGENT_PORT=9899
LIGHTAGENT_WEB_PASSWORD=CHANGE_THIS_LIGHTAGENT_PASSWORD
LIGHTAGENT_PUSH_TOKEN=CHANGE_THIS_LIGHTAGENT_PUSH_TOKEN
LIGHTAGENT_CHANNEL_TYPE=web,wechat_group
LIGHTAGENT_MODEL=deepseek-v4-flash
NOTIFICATION_SENDER_TYPE=lightagent
LIGHTAGENT_NOTIFY_URL=http://lightagent:9899/api/push/send
LIGHTAGENT_NOTIFY_TARGET=
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
WECHAT_GROUP_ENABLED=true
INSTALL_LIGHTAGENT_BROWSER=false

# 企业微信自建应用
WECOM_CORP_ID=YOUR_CORP_ID_HERE
WECOM_CORP_SECRET=YOUR_CORP_SECRET_HERE
WECOM_AGENT_ID=1000001
